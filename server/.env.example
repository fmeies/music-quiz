SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
APP_URL=https://your-domain.com
REDIRECT_URI=https://your-domain.com/music-quiz/auth/spotify/callback
PORT=3011
APP_CODE=your_secret_access_code

# Preset playlists. Each must be a playlist the connecting host OWNS or
# collaborates on — since Spotify's Feb/Mar 2026 API migration, third-party
# playlists (e.g. official HITSTER lists) return 403. To use one, duplicate it
# into your own Spotify account and point the URL at the copy.
PLAYLIST_1_NAME=My Playlist
PLAYLIST_1_URL=https://open.spotify.com/playlist/xxx

PLAYLIST_2_NAME=Another Playlist
PLAYLIST_2_URL=https://open.spotify.com/playlist/yyy
